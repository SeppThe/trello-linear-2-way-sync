{
  "name": "Trello-Linear-2-way-sync",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @Trello-Linear-2-way-sync/db db:push",
    "db:studio": "turbo -F @Trello-Linear-2-way-sync/db db:studio",
    "db:generate": "turbo -F @Trello-Linear-2-way-sync/db db:generate",
    "db:migrate": "turbo -F @Trello-Linear-2-way-sync/db db:migrate",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@Trello-Linear-2-way-sync/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Trello-Linear-2-way-sync/config": "workspace:*",
    "@biomejs/biome": "^2.2.0",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
